CLINIC_NAME=Consultorio Demo Citas
TIMEZONE=America/Mexico_City

# Nivel de logs de Baileys: silent, error, warn, info, debug
# warn: menos ruido. silent: oculta tambien errores de descifrado al conectar (sincronizacion de WhatsApp).
BAILEYS_LOG_LEVEL=warn

# Numeros de doctor/recepcion autorizados para comandos internos.
# Formato: solo digitos separados por coma, o lid:ID si WhatsApp usa JID @lid.
# Ej: 5215512345678,lid:89537468494034
DOCTOR_NUMBERS=
