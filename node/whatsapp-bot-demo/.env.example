# Copia este archivo a .env y rellena los valores (Meta > WhatsApp > API setup)

# Token temporal de 24h o token de larga duración (System User) — ver README
WHATSAPP_TOKEN=

# Phone number ID (no es el número en dígitos; es el ID de la API)
WHATSAPP_PHONE_NUMBER_ID=

# Debe coincidir EXACTAMENTE con lo que pongas al configurar el Webhook en Meta
WEBHOOK_VERIFY_TOKEN=mi_token_secreto_demo_123

# Puerto local del servidor
PORT=3000
